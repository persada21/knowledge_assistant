<div class="mb-8 flex items-start justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= @document.title %></h1>
    <p class="text-sm text-gray-400 mt-1">
      Uploaded <%= time_ago_in_words(@document.created_at) %> ago
    </p>
  </div>

  <span class="px-3 py-1 rounded-full text-sm font-medium <%= status_badge_class(@document.status) %>">
    <%= @document.status.capitalize %>
  </span>
</div>

<% if @document.pending? || @document.processing? %>
  <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 mb-6 text-center">
    <p class="text-yellow-800 font-medium text-lg mb-1">Processing your document...</p>
    <p class="text-yellow-700 text-sm">
      Sidekiq is chunking and indexing your content in the background.
      This page refreshes automatically.
    </p>
    <meta http-equiv="refresh" content="3">
  </div>

<% elsif @document.failed? %>
  <div class="bg-red-50 border border-red-200 rounded-xl p-6 mb-6">
    <p class="text-red-800 font-medium mb-1">Processing failed</p>
    <p class="text-red-700 text-sm">
      Something went wrong while processing this document. Please try uploading again.
    </p>
  </div>

<% else %>
  <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6">
    <p class="text-green-800 text-sm font-medium">
      Ready &mdash; <%= @document.chunk_count %> chunks indexed
    </p>
  </div>

  <%= link_to "Ask a question about this document &rarr;".html_safe, new_question_path,
      class: "inline-block mb-8 bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700" %>

  <h2 class="text-lg font-semibold text-gray-800 mb-4">Indexed Chunks</h2>
  <div class="space-y-3">
    <% @chunks.each do |chunk| %>
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-1 rounded">
            Chunk #<%= chunk.chunk_index %>
          </span>
          <span class="text-xs text-gray-400"><%= chunk.word_count %> words</span>
        </div>
        <p class="text-gray-700 text-sm leading-relaxed whitespace-pre-line"><%= chunk.body %></p>
      </div>
    <% end %>
  </div>
<% end %>

<div class="mt-8">
  <%= link_to "&larr; All Documents".html_safe, documents_path, class: "text-blue-600 hover:underline text-sm" %>
</div>
