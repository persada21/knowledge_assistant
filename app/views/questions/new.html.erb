<h1 class="text-2xl font-bold text-gray-900 mb-2">Ask a Question</h1>
<p class="text-gray-500 mb-8">
  The assistant will search through all uploaded documents to find your answer.
</p>

<div class="bg-white rounded-xl border border-gray-200 p-8">
  <%= form_with url: questions_path, method: :post do |f| %>
    <div class="mb-6">
      <%= f.label :question, "Your Question", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_area :question,
          rows: 3,
          placeholder: "e.g. What is the main idea of this document? How does X work?",
          class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <%= f.submit "Find Answer",
        class: "bg-blue-600 text-white px-8 py-3 rounded-lg hover:bg-blue-700 cursor-pointer font-medium" %>
  <% end %>
</div>

<% if @documents.any? %>
  <div class="mt-10">
    <h2 class="text-sm font-medium text-gray-500 mb-4">
      Searching across <%= @documents.count %> document(s):
    </h2>
    <div class="flex flex-wrap gap-2">
      <% @documents.each do |doc| %>
        <span class="bg-gray-100 text-gray-700 text-sm px-3 py-1 rounded-full">
          <%= doc.title %>
        </span>
      <% end %>
    </div>
  </div>
<% end %>
