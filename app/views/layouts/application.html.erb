<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for(:title) || "Knowledge Assistant" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200 px-6 py-4">
      <div class="max-w-4xl mx-auto flex items-center justify-between">
        <%= link_to "Knowledge Assistant", root_path, class: "text-xl font-semibold text-gray-800" %>
        <div class="flex gap-6 text-sm">
          <%= link_to "Upload",         new_document_path, class: "text-gray-600 hover:text-gray-900" %>
          <%= link_to "Documents",      documents_path,    class: "text-gray-600 hover:text-gray-900" %>
          <%= link_to "Ask a Question", new_question_path, class: "text-gray-600 hover:text-gray-900" %>
        </div>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-6 py-10">
      <% if notice %>
        <div class="mb-6 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
